!/.eslintrc.json
!/project.json

/test-reports

# -------------------------------------
# Terraform
# -------------------------------------

# Terraform working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform variable files
*.tfvars
*.tfvars.json

# Terraform plan files
tfplan
*.tfplan

# Terraform crash logs
crash.log
crash.*.log

# Terraform lock files
.terraform.tfstate.lock.info

# Terraform CLI config
.terraformrc
terraform.rc

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -------------------------------------
# Local project artifacts
# -------------------------------------

# Terraform backup created before module migration
state-backup-before-modules.json
infra/state-backup-before-modules.json

# Local Terraform plan outputs
infra/tfplan
infra/*.tfplan